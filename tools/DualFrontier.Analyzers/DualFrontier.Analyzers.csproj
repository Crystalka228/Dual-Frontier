<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <!-- CRITICAL: override Directory.Build.props net8.0 default per Q-L-4 + S-LOCK-2 + recon §7.1.2 -->
    <!-- Roslyn analyzer host loads compatibility requires netstandard2.0 -->
    <TargetFramework>netstandard2.0</TargetFramework>
    <!-- Pinned explicit per STACK_UPDATE D2: 'latest' is machine-dependent (floats
         with the installed SDK's compiler); 14.0 is what it resolved to here. -->
    <LangVersion>14.0</LangVersion>

    <AssemblyName>DualFrontier.Analyzers</AssemblyName>
    <RootNamespace>DualFrontier.Analyzers</RootNamespace>

    <!-- Roslyn analyzer machinery -->
    <IsRoslynComponent>true</IsRoslynComponent>
    <EnforceExtendedAnalyzerRules>true</EnforceExtendedAnalyzerRules>

    <!-- Internal-only — no NuGet publication per recon §7.4.4 -->
    <IsPackable>false</IsPackable>

    <!-- Inherits Nullable=enable, ImplicitUsings=enable, TreatWarningsAsErrors=true, GenerateDocumentationFile=true -->
    <!-- from Directory.Build.props (RS1015 helpLinkUri enforced per recon §7.1.5) -->
  </PropertyGroup>

  <!--
    Per Q-L-6 CPM: package versions resolved via repo-root Directory.Packages.props.
    Per recon §7.1.5: Microsoft.CodeAnalysis.CSharp 5.3.0 pinned baseline (centralized).
  -->
  <ItemGroup>
    <PackageReference Include="Microsoft.CodeAnalysis.CSharp" PrivateAssets="all" />
    <PackageReference Include="Microsoft.CodeAnalysis.Analyzers" PrivateAssets="all">
      <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
    </PackageReference>
  </ItemGroup>

  <ItemGroup>
    <!--
      RS2008 release tracking infrastructure per Roslyn canonical authoring pattern.
      Added at A'.9.1 Phase β-prep Commit β1 (К-extensions cascade #5).

      Governance benefit per PA-002 (canonical pattern over NoWarn kostyl) + PA-003 (long-horizon
      complexity justified): AnalyzerReleases tracks per-cascade rule additions/changes/removals.
      Unshipped.md updates per Phase β-prep commit (β1 9 Architecture; β2 5 NativeBoundary;
      β3 3 Discipline). Shipped.md becomes populated at A'.9.1 closure when ruleset «ships»
      per Phase γ severity promotion.
    -->
    <AdditionalFiles Include="AnalyzerReleases.Shipped.md" />
    <AdditionalFiles Include="AnalyzerReleases.Unshipped.md" />
  </ItemGroup>

  <!--
    NOTE on [ReservedStub] attribute access (Q-L-10 + S-LOCK-12):
    Brief §6.1 specified a ProjectReference к DualFrontier.Contracts here. That was an
    architectural over-specification — netstandard2.0 (mandatory per Q-L-4 for Roslyn host
    load compat) cannot ProjectReference net10.0 (Contracts target per Directory.Build.props)
    even with ReferenceOutputAssembly="false"; the framework compatibility check fires before
    the assembly-output skip.

    The reference is also architecturally unnecessary: Roslyn analyzers detect attributes
    via the SemanticModel by fully-qualified name string comparison, not by compile-time
    CLR type reference. The Phase β DFL025-A detection logic will use:

        attr.AttributeClass?.ToDisplayString() == "DualFrontier.Contracts.Analyzer.ReservedStubAttribute"

    This is the canonical Roslyn analyzer pattern (every published analyzer in the .NET
    ecosystem operates this way — analyzers run in the compiler host, the analyzed code
    is a separate Compilation surface accessed via Microsoft.CodeAnalysis APIs).

    К-L14 thesis: tooling addition. PA-002 axiom: dropping the unnecessary ProjectReference
    avoids a kostyl-shaped framework-version workaround.
  -->

</Project>
