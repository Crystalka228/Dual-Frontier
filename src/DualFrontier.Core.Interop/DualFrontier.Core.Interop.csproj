<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <AssemblyName>DualFrontier.Core.Interop</AssemblyName>
    <RootNamespace>DualFrontier.Core.Interop</RootNamespace>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
    <Description>
      Experimental P/Invoke wrappers for the native DualFrontier.Core.Native
      library. Kept as a separate assembly so the managed Core stays
      untouched while the C++ experiment is being evaluated.
    </Description>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\DualFrontier.Contracts\DualFrontier.Contracts.csproj" />
  </ItemGroup>

  <ItemGroup>
    <InternalsVisibleTo Include="DualFrontier.Core.Benchmarks" />
    <InternalsVisibleTo Include="DualFrontier.Core.Interop.Tests" />
    <!-- K10.1 Item 15 — Application's SchedulerAdapter calls the internal
         NativeMethods directly к bind ManagedSystemDispatcher.OnBatch к
         the native scheduler. -->
    <InternalsVisibleTo Include="DualFrontier.Application" />
    <!-- K10.1 Item 24 — Core.Tests fixture ManagedTestScheduler needs к
         reset native scheduler singletons (state filter, trace, intrinsics,
         managed callback) for test isolation. -->
    <InternalsVisibleTo Include="DualFrontier.Core.Tests" />
  </ItemGroup>
</Project>
