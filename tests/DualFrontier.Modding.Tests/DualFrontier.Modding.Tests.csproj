<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <AssemblyName>DualFrontier.Modding.Tests</AssemblyName>
    <RootNamespace>DualFrontier.Modding.Tests</RootNamespace>
    <IsPackable>false</IsPackable>
    <GenerateDocumentationFile>false</GenerateDocumentationFile>
  </PropertyGroup>
  <ItemGroup>
    <PackageReference Include="Microsoft.NET.Test.Sdk" Version="17.11.1" />
    <PackageReference Include="xunit" Version="2.9.2" />
    <PackageReference Include="xunit.runner.visualstudio" Version="2.8.2" />
    <PackageReference Include="FluentAssertions" Version="6.12.1" />
  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="..\..\src\DualFrontier.Application\DualFrontier.Application.csproj" />
  </ItemGroup>
  <!--
    K8.2 v2 — native DLL must ride along into test output: tests now exercise
    GameBootstrap.CreateLoop and RandomPawnFactory, both of which construct a
    NativeWorld for InternedString interning on struct components. Without
    this, P/Invoke fails with DllNotFoundException. Mirrors the
    DualFrontier.Core.Interop.Tests + DualFrontier.Core.Benchmarks pattern.
  -->
  <ItemGroup>
    <None Include="$(MSBuildThisFileDirectory)..\..\native\DualFrontier.Core.Native\build\Release\DualFrontier.Core.Native.dll"
          Condition="Exists('$(MSBuildThisFileDirectory)..\..\native\DualFrontier.Core.Native\build\Release\DualFrontier.Core.Native.dll')">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
      <Link>DualFrontier.Core.Native.dll</Link>
    </None>
  </ItemGroup>
  <!--
    The fixture mods are built solely so their assemblies and manifests
    end up in this project's bin/<config>/<tfm>/Fixtures/<assembly>/.
    ReferenceOutputAssembly=false keeps their types out of the test
    compilation so the test process never loads them into the default
    AssemblyLoadContext — that is critical for cross-ALC tests, which
    need to load each fixture into a freshly created context.
  -->
  <ItemGroup>
    <ProjectReference Include="..\Fixture.SharedEvents\Fixture.SharedEvents.csproj">
      <ReferenceOutputAssembly>false</ReferenceOutputAssembly>
      <Private>false</Private>
    </ProjectReference>
    <ProjectReference Include="..\Fixture.PublisherMod\Fixture.PublisherMod.csproj">
      <ReferenceOutputAssembly>false</ReferenceOutputAssembly>
      <Private>false</Private>
    </ProjectReference>
    <ProjectReference Include="..\Fixture.SubscriberMod\Fixture.SubscriberMod.csproj">
      <ReferenceOutputAssembly>false</ReferenceOutputAssembly>
      <Private>false</Private>
    </ProjectReference>
    <ProjectReference Include="..\Fixture.BadRegularMod\Fixture.BadRegularMod.csproj">
      <ReferenceOutputAssembly>false</ReferenceOutputAssembly>
      <Private>false</Private>
    </ProjectReference>
    <ProjectReference Include="..\Fixture.BadSharedMod_WithIMod\Fixture.BadSharedMod_WithIMod.csproj">
      <ReferenceOutputAssembly>false</ReferenceOutputAssembly>
      <Private>false</Private>
    </ProjectReference>
    <ProjectReference Include="..\Fixture.RegularMod_DependsOnAnother\Fixture.RegularMod_DependsOnAnother.csproj">
      <ReferenceOutputAssembly>false</ReferenceOutputAssembly>
      <Private>false</Private>
    </ProjectReference>
    <ProjectReference Include="..\Fixture.RegularMod_DependedOn\Fixture.RegularMod_DependedOn.csproj">
      <ReferenceOutputAssembly>false</ReferenceOutputAssembly>
      <Private>false</Private>
    </ProjectReference>
    <ProjectReference Include="..\Fixture.RegularMod_CyclicA\Fixture.RegularMod_CyclicA.csproj">
      <ReferenceOutputAssembly>false</ReferenceOutputAssembly>
      <Private>false</Private>
    </ProjectReference>
    <ProjectReference Include="..\Fixture.RegularMod_CyclicB\Fixture.RegularMod_CyclicB.csproj">
      <ReferenceOutputAssembly>false</ReferenceOutputAssembly>
      <Private>false</Private>
    </ProjectReference>
    <ProjectReference Include="..\Fixture.RegularMod_MissingRequired\Fixture.RegularMod_MissingRequired.csproj">
      <ReferenceOutputAssembly>false</ReferenceOutputAssembly>
      <Private>false</Private>
    </ProjectReference>
    <ProjectReference Include="..\Fixture.RegularMod_MissingOptional\Fixture.RegularMod_MissingOptional.csproj">
      <ReferenceOutputAssembly>false</ReferenceOutputAssembly>
      <Private>false</Private>
    </ProjectReference>
    <ProjectReference Include="..\Fixture.RegularMod_BadApiVersion\Fixture.RegularMod_BadApiVersion.csproj">
      <ReferenceOutputAssembly>false</ReferenceOutputAssembly>
      <Private>false</Private>
    </ProjectReference>
    <ProjectReference Include="..\Fixture.RegularMod_DepsBadVersion\Fixture.RegularMod_DepsBadVersion.csproj">
      <ReferenceOutputAssembly>false</ReferenceOutputAssembly>
      <Private>false</Private>
    </ProjectReference>
    <ProjectReference Include="..\Fixture.RegularMod_DependsOnBadApi\Fixture.RegularMod_DependsOnBadApi.csproj">
      <ReferenceOutputAssembly>false</ReferenceOutputAssembly>
      <Private>false</Private>
    </ProjectReference>
    <ProjectReference Include="..\Fixture.RegularMod_ReplacesCombat\Fixture.RegularMod_ReplacesCombat.csproj">
